# ========= DATABASE (LOCAL - para desarrollo) =========
# Copiá este archivo a .env y usá estas URLs para trabajar en localhost.
# Para migrar o crear superadmin en Neon, NO edites .env: usá .env.production.local
# con DATABASE_URL, DIRECT_URL y opcionalmente SUPER_ADMIN_PASSWORD; luego
# pnpm db:migrate:deploy:prod y pnpm db:create-superadmin:prod. Ver docs/DEPLOY.md.

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bloqer"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/bloqer"

# ========= AUTH (DEV) =========
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="dev-secret-change-me"
