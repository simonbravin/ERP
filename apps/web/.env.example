# Auth (next-auth v5 / Auth.js) — required in production. Must match the app URL (dev runs on 3333).
NEXTAUTH_URL="http://localhost:3333"
# Public app URL (emails, links). Production: same as NEXTAUTH_URL.
NEXT_PUBLIC_APP_URL="http://localhost:3333"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
# Opcional: Auth.js también lee AUTH_SECRET/AUTH_URL; si no están, la app usa NEXTAUTH_*. En Vercel basta con NEXTAUTH_*.
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Database (Prisma + Neon in production). In Neon: use pooled URL for DATABASE_URL, direct for DIRECT_URL.
# Local: same URL for both, sslmode=disable. Neon: DATABASE_URL = ...@pooler.region.neon.tech/...?sslmode=require&pgbouncer=true
DATABASE_URL="postgresql://user:password@localhost:5432/construction_erp?sslmode=disable"
# Required for Prisma migrations on Neon (direct connection, no pooler). Local: same as DATABASE_URL.
DIRECT_URL="postgresql://user:password@localhost:5432/construction_erp?sslmode=disable"

# Email (Resend) — required in production for invitation and password-reset emails
# Without RESEND_API_KEY, those emails are not sent (invites are stored; reset returns 500).
RESEND_API_KEY=
# Remitente de los emails. En producción usar ej. Bloqer <noreply@bloqer.app>
EMAIL_FROM=Bloqer <noreply@bloqer.app>
# Alias opcional; si no está EMAIL_FROM se usa este
RESEND_FROM_EMAIL=Bloqer <onboarding@resend.dev>
# Opcional: secret para permitir POST /api/email/test en producción (query ?secret= o header X-Email-Test-Secret)
# EMAIL_TEST_SECRET=

# Reporte semanal por email (viernes 9:00 Argentina). Solo se envía si WEEKLY_REPORT_ENABLED=true. Requiere Inngest + Resend.
# WEEKLY_REPORT_ENABLED=true

# Cloudflare R2 (optional for dev - uploads are no-op without these)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=construction-erp-dev

# Billing (Paddle). Sandbox vs live is typically selected via PADDLE_ENV and API keys.
# See docs/06-billing/paddle-billing-architecture.md
PADDLE_ENV=sandbox
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
# Optional: client token if using Paddle.js on the client.
# NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=

# When false (default), orgs without OrganizationSubscription use legacy Organization fields for access.
# Set to true only after backfill / Paddle is syncing subscriptions.
BILLING_ENFORCEMENT_ENABLED=false

# Inngest or similar: optional billing reminder jobs.
BILLING_REMINDERS_ENABLED=false

# Optional: seed BillingPlan + BillingPlanPrice with real Paddle price IDs (pnpm --filter @repo/database db:seed-billing-catalog).
# BILLING_SEED_PLAN_CODE=STANDARD
# BILLING_SEED_PLAN_NAME=Standard
# BILLING_SEED_TRIAL_DAYS=14
# BILLING_SEED_PADDLE_PRICE_MONTHLY=pri_...
# BILLING_SEED_PADDLE_PRICE_YEARLY=pri_...
# BILLING_SEED_AMOUNT_MONTHLY_USD=29
# BILLING_SEED_AMOUNT_YEARLY_USD=290

